generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// ============================
// ORGANIZATION（テナント）
// ============================
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  companies     Company[]
  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  sequences     Sequence[]
  knowledgeDocs KnowledgeDoc[]
  ragQueries    RagQuery[]
}

enum Plan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

// ============================
// USER
// ============================
model User {
  id           String   @id @default(cuid())
  orgId        String
  email        String
  name         String
  role         UserRole @default(REP)
  avatarUrl    String?
  googleUserId String?
  slackUserId  String?
  createdAt    DateTime @default(now())

  org            Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedDeals     Deal[]              @relation("DealOwner")
  ownedCompanies Company[]           @relation("CompanyOwner")
  tasks          Task[]
  activities     Activity[]
  googleAccount  UserGoogleAccount?
  emailMessages  EmailMessage[]
  meetingEvents  MeetingEvent[]

  @@unique([orgId, email])
  @@index([orgId])
}

enum UserRole {
  ADMIN
  MANAGER
  REP
}

// ============================
// COMPANY（企業）
// ============================
model Company {
  id              String         @id @default(cuid())
  orgId           String
  name            String
  domain          String?
  phone           String?
  industry        String?
  employeeRange   EmployeeRange?
  revenueRange    RevenueRange?
  prefecture      String?
  corporateNumber String?
  masterCompanyId String?
  leadSource      LeadSource?
  leadScore       Int            @default(0)
  leadRank        LeadRank       @default(D)
  ownerId         String
  lastScoreCalcAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner         User           @relation("CompanyOwner", fields: [ownerId], references: [id])
  masterCompany CompanyMaster? @relation(fields: [masterCompanyId], references: [id], onDelete: SetNull)
  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  scoreEvents   ScoreEvent[]
  emailMessages EmailMessage[]
  meetingEvents MeetingEvent[]

  @@index([orgId, leadScore(sort: Desc)])
  @@index([orgId, domain])
  @@index([orgId, leadRank])
  @@index([orgId, masterCompanyId])
}

enum EmployeeRange {
  E1_10
  E11_50
  E51_200
  E201_1000
  E1000_PLUS
}

enum RevenueRange {
  R_UNDER_10M
  R10M_100M
  R100M_1B
  R1B_PLUS
}

enum LeadRank {
  S
  A
  B
  C
  D
}

enum LeadSource {
  HP_INQUIRY
  PRICING_INQUIRY
  DOCUMENT_REQUEST
  SEMINAR_OWN
  SEMINAR_CO
  REFERRAL
  EVENT
  PAID_SEARCH
  PAID_SOCIAL
  ORGANIC
  PARTNER
  CSV_IMPORT
}

// ============================
// CONTACT（担当者）
// ============================
model Contact {
  id              String   @id @default(cuid())
  orgId           String
  companyId       String
  name            String
  email           String?
  phone           String?
  title           String?
  department      String?
  isDecisionMaker Boolean  @default(false)

  // IS フィールド
  isOwnerId        String?
  approachStatus   ApproachStatus  @default(NOT_STARTED)
  callAttempts     Int             @default(0)
  lastCallAt       DateTime?
  lastCallResult   CallResult?
  emailSentCount   Int             @default(0)
  lastEmailAt      DateTime?
  lastEmailOpenAt  DateTime?
  nextActionAt     DateTime?
  currentSeqId     String?
  sequenceStatus   SequenceStatus?
  bestCallTimeSlot String?
  doNotContact     Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals         Deal[]
  activities    Activity[]
  tasks         Task[]
  currentSeq    Sequence?      @relation(fields: [currentSeqId], references: [id])
  emailMessages EmailMessage[]
  meetingEvents MeetingEvent[]

  @@index([orgId, approachStatus])
  @@index([orgId, companyId])
  @@index([orgId, doNotContact])
}

enum ApproachStatus {
  NOT_STARTED
  NO_ANSWER
  ABSENT
  CONNECTED
  DO_NOT_CALL
  APPOINTMENT_SET
  NEXT_ACTION
}

enum SequenceStatus {
  ACTIVE
  COMPLETED
  PAUSED
  GRADUATED
  DOWNGRADED
}

enum CallResult {
  CONNECTED_INTERESTED
  CONNECTED_FOLLOWUP_REQUESTED
  CONNECTED_NO_INTEREST
  MEETING_BOOKED
  NO_ANSWER
  CALLBACK_REQUESTED
  DEPARTMENT_CONNECTED_ABSENT
  WRONG_CONTACT
  INVALID_NUMBER
  DO_NOT_CALL
}

// ============================
// DEAL（商談）
// ============================
model Deal {
  id              String    @id @default(cuid())
  orgId           String
  name            String
  companyId       String
  contactId       String?
  ownerId         String
  stage           DealStage @default(NEW_LEAD)
  amount          Int?
  expectedCloseAt DateTime?
  probability     Int?

  // AI自動抽出フィールド（議事録から）
  painPoints      String?
  budget          String?
  desiredService  String?
  timeline        String?
  decisionMaker   String?
  competitors     String?
  blockers        String?
  currentSolution String?
  nextActionUs    String?
  nextActionCust  String?
  fieldMeta       Json? // { fieldName: { source, confidence, updatedAt } }

  lostReason      String?
  lostReasonAiSug String?

  stalledAt      DateTime?
  stageChangedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id])
  contact       Contact?       @relation(fields: [contactId], references: [id])
  owner         User           @relation("DealOwner", fields: [ownerId], references: [id])
  activities    Activity[]
  tasks         Task[]
  transcripts   Transcript[]
  researchBrief ResearchBrief?
  stageHistory  StageHistory[]
  emailMessages EmailMessage[]
  meetingEvents MeetingEvent[]

  @@index([orgId, stage])
  @@index([orgId, ownerId])
  @@index([orgId, stalledAt])
  @@index([orgId, updatedAt(sort: Desc)])
}

enum DealStage {
  NEW_LEAD
  QUALIFIED
  FIRST_MEETING
  SOLUTION_FIT
  PROPOSAL
  NEGOTIATION
  VERBAL_COMMIT
  CLOSED_WON
  CLOSED_LOST
}

// ============================
// ACTIVITY（活動記録）
// ============================
model Activity {
  id         String       @id @default(cuid())
  orgId      String
  dealId     String?
  contactId  String?
  companyId  String?
  userId     String
  type       ActivityType
  title      String
  content    String?
  resultCode CallResult?
  metadata   Json?
  occurredAt DateTime     @default(now())
  createdAt  DateTime     @default(now())

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal    Deal?        @relation(fields: [dealId], references: [id])
  contact Contact?     @relation(fields: [contactId], references: [id])
  company Company?     @relation(fields: [companyId], references: [id])
  user    User         @relation(fields: [userId], references: [id])

  @@index([orgId, dealId])
  @@index([orgId, contactId])
  @@index([orgId, occurredAt(sort: Desc)])
}

enum ActivityType {
  CALL
  EMAIL_SENT
  EMAIL_RECEIVED
  MEETING
  NOTE
  STAGE_CHANGED
  TASK_COMPLETED
  SEQUENCE_STARTED
  SEQUENCE_COMPLETED
  SCORE_CHANGED
}

// ============================
// TASK（タスク）
// ============================
model Task {
  id               String      @id @default(cuid())
  orgId            String
  dealId           String?
  contactId        String?
  companyId        String?
  ownerId          String
  type             TaskType
  title            String
  memo             String?
  dueAt            DateTime
  completedAt      DateTime?
  resultCode       CallResult?
  source           TaskSource
  reminderSettings Json?
  sequenceId       String?
  sequenceStepIdx  Int?
  createdAt        DateTime    @default(now())

  deal    Deal?    @relation(fields: [dealId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  owner   User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId, dueAt])
  @@index([ownerId, completedAt])
  @@index([orgId, dueAt])
}

enum TaskType {
  CALL
  EMAIL
  DOCUMENT
  MEETING_PREP
  PROPOSAL
  OTHER
}

enum TaskSource {
  SEQUENCE_AUTO
  MODAL_MANUAL
  MEETING_NOTES
  MANUAL
}

// ============================
// SCORING
// ============================
model ScoreEvent {
  id         String   @id @default(cuid())
  companyId  String
  signal     String
  points     Int
  metadata   Json?
  occurredAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, occurredAt(sort: Desc)])
}

// ============================
// SEQUENCE
// ============================
model Sequence {
  id        String         @id @default(cuid())
  orgId     String
  name      String
  rank      LeadRank
  steps     SequenceStep[]
  contacts  Contact[]
  createdAt DateTime       @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, rank])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  stepOrder  Int
  type       TaskType
  dayOffset  Int
  subject    String?
  bodyTmpl   String?

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId, stepOrder])
}

// ============================
// TRANSCRIPT（文字起こし）
// ============================
model Transcript {
  id              String         @id @default(cuid())
  orgId           String
  dealId          String?
  companyId       String?
  contactId       String?
  type            TranscriptType
  fullText        String
  audioUrl        String?
  durationSec     Int?
  extractedFields Json?
  confidence      Json?
  stageAdvanced   Boolean        @default(false)
  createdAt       DateTime       @default(now())

  // Google Meet 連携メタデータ
  meetingEventId     String?  @unique
  conferenceRecordId String?  @unique // Meet API: conferenceRecords/{name}
  googleDocId        String?           // 議事録 Google Doc の Drive file ID
  googleDocUrl       String?
  source             TranscriptSource @default(MANUAL)

  deal         Deal?         @relation(fields: [dealId], references: [id])
  meetingEvent MeetingEvent? @relation(fields: [meetingEventId], references: [id])

  @@index([dealId, createdAt(sort: Desc)])
  @@index([conferenceRecordId])
}

enum TranscriptType {
  CALL
  MEETING
}

enum TranscriptSource {
  MANUAL
  GOOGLE_MEET
  ZOOM
  OTHER
}

// ============================
// STAGE HISTORY
// ============================
model StageHistory {
  id        String     @id @default(cuid())
  dealId    String
  fromStage DealStage?
  toStage   DealStage
  changedBy String
  reason    String?
  changedAt DateTime   @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, changedAt])
}

// ============================
// RESEARCH BRIEF
// ============================
model ResearchBrief {
  id                  String   @id @default(cuid())
  dealId              String   @unique
  companyName         String
  businessSummary     String?
  industry            String?
  employeeCount       String?
  foundedYear         String?
  fundingStatus       String?
  ceoName             String?
  ceoBackground       String?
  challenges          Json?
  salesOrgHypothesis  String?
  toolsUsed           Json?
  recommendedApproach String?
  questionsToAsk      Json?
  rawData             Json?
  confidence          Json?
  generatedAt         DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ============================
// KNOWLEDGE / RAG
// ============================
model KnowledgeDoc {
  id           String   @id @default(cuid())
  orgId        String
  sourceType   String
  sourceId     String
  fileName     String
  fileUrl      String
  mimeType     String
  lastModified DateTime
  indexedAt    DateTime @default(now())

  org    Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@unique([orgId, sourceId])
  @@index([orgId])
}

model KnowledgeChunk {
  id         String                      @id @default(cuid())
  docId      String
  content    String
  embedding  Unsupported("vector(1536)")?
  metadata   Json?
  chunkIndex Int
  createdAt  DateTime                    @default(now())

  doc KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
}

model RagQuery {
  id         String   @id @default(cuid())
  orgId      String
  userId     String?
  query      String
  answer     String
  sources    Json?
  confidence Float?
  feedback   Int?
  slackTs    String?
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt(sort: Desc)])
}

// ================================================================
// COMPANY MASTER（テナント非依存の企業マスター）
// 全テナントで共有される企業DB。abm-toolから移行したデータを保持。
// ================================================================
model CompanyMaster {
  id               String           @id @default(cuid())
  corporateNumber  String           @unique
  name             String
  nameKana         String?
  websiteUrl       String?
  prefecture       String
  city             String?
  address          String?
  corporateType    String
  industryId       String?
  serviceSummary   String?
  companyFeatures  String?
  employeeCount    String?
  revenue          String?
  representative   String?
  representativePhone String?
  representativeEmail String?
  enrichmentStatus EnrichmentStatus @default(PENDING)
  sourceId         String?
  lastCrawledAt    DateTime?
  lastEnrichedAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  industry         Industry?              @relation(fields: [industryId], references: [id])
  offices          Office[]
  departments      Department[]
  intentSignals    IntentSignal[]
  companyIntents   CompanyIntent[]
  serviceTags      CompanyServiceTag[]
  linkedCompanies  Company[]

  @@index([name])
  @@index([prefecture])
  @@index([enrichmentStatus])
  @@index([industryId])
  @@index([employeeCount])
  @@index([lastCrawledAt])
}

enum EnrichmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// 業種マスタ（industries）
model Industry {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String?
  createdAt DateTime @default(now())

  companies CompanyMaster[]
}

// サービスタグマスタ（service_tags）
model ServiceTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  companies CompanyServiceTag[]
}

// 企業×サービスタグ中間テーブル
model CompanyServiceTag {
  companyMasterId String
  tagId           String
  createdAt       DateTime @default(now())

  companyMaster CompanyMaster @relation(fields: [companyMasterId], references: [id], onDelete: Cascade)
  tag           ServiceTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyMasterId, tagId])
  @@index([tagId])
}

// 拠点（offices）
model Office {
  id              String     @id @default(cuid())
  companyMasterId String
  name            String
  officeType      OfficeType @default(BRANCH)
  prefecture      String?
  city            String?
  address         String?
  phone           String?
  websiteUrl      String?
  isPrimary       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  companyMaster CompanyMaster @relation(fields: [companyMasterId], references: [id], onDelete: Cascade)
  departments   Department[]

  @@index([companyMasterId])
  @@index([officeType])
  @@index([prefecture])
}

enum OfficeType {
  HEADQUARTERS
  BRANCH
  SALES_OFFICE
  FACTORY
  LAB
  OTHER
}

// 部門（departments、ツリー構造）
model Department {
  id                 String          @id @default(cuid())
  companyMasterId    String
  officeId           String?
  parentDepartmentId String?
  name               String
  departmentType     DepartmentType?
  headcount          String?
  description        String?
  phone              String?
  email              String?
  contactPersonName  String?
  contactPersonTitle String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  companyMaster    CompanyMaster   @relation(fields: [companyMasterId], references: [id], onDelete: Cascade)
  office           Office?         @relation(fields: [officeId], references: [id], onDelete: SetNull)
  parentDepartment Department?     @relation("DepartmentTree", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]    @relation("DepartmentTree")
  intentSignals    IntentSignal[]
  companyIntents   CompanyIntent[]

  @@index([companyMasterId])
  @@index([officeId])
  @@index([departmentType])
  @@index([parentDepartmentId])
}

enum DepartmentType {
  SALES
  MARKETING
  ENGINEERING
  IT
  HR
  FINANCE
  LEGAL
  OPERATIONS
  MANAGEMENT
  RD
  CS
  OTHER
}

// インテント個別シグナル（求人情報・プレスリリース）
model IntentSignal {
  id              String            @id @default(cuid())
  companyMasterId String
  departmentType  DepartmentType?
  departmentId    String?
  signalType      IntentSignalType
  source          String
  sourceUrl       String
  title           String
  description     String?
  publishedAt     DateTime?
  rawData         Json?
  createdAt       DateTime          @default(now())

  companyMaster CompanyMaster @relation(fields: [companyMasterId], references: [id], onDelete: Cascade)
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([companyMasterId, sourceUrl])
  @@index([companyMasterId, publishedAt(sort: Desc)])
  @@index([companyMasterId, departmentType])
  @@index([departmentId])
  @@index([signalType])
  @@index([publishedAt(sort: Desc)])
}

enum IntentSignalType {
  JOB_POSTING
  PRESS_RELEASE
  NEWS
  FUNDING
  PRODUCT_LAUNCH
  EVENT
  OTHER
}

// 企業×部門の集約インテント（スコアリング用）
model CompanyIntent {
  id              String         @id @default(cuid())
  companyMasterId String
  departmentType  DepartmentType
  departmentId    String?
  intentLevel     IntentLevel    @default(NONE)
  signalCount     Int            @default(0)
  latestSignalAt  DateTime?
  updatedAt       DateTime       @updatedAt

  companyMaster CompanyMaster @relation(fields: [companyMasterId], references: [id], onDelete: Cascade)
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([companyMasterId, departmentType])
  @@index([intentLevel])
  @@index([companyMasterId])
  @@index([departmentType])
  @@index([latestSignalAt(sort: Desc)])
}

enum IntentLevel {
  HOT
  MIDDLE
  LOW
  NONE
}

// ============================
// GOOGLE 連携 — OAuth トークン保存
// ============================
model UserGoogleAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  googleSub    String    @unique
  email        String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  // Gmail History API 用カーソル（差分同期）
  gmailHistoryId String?
  // Calendar 同期トークン
  calendarSyncToken String?
  // 最終同期時刻（観測用）
  lastGmailSyncAt    DateTime?
  lastCalendarSyncAt DateTime?
  lastMeetSyncAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================
// GMAIL — メールメッセージ
// ============================
model EmailMessage {
  id             String         @id @default(cuid())
  orgId          String
  userId         String
  gmailMessageId String
  gmailThreadId  String
  subject        String?
  snippet        String?
  bodyText       String?
  bodyHtml       String?
  fromAddress    String
  fromName       String?
  toAddresses    String[]       @default([])
  ccAddresses    String[]       @default([])
  sentAt         DateTime
  direction      EmailDirection
  labels         String[]       @default([])

  // 紐付け（メアド一致で自動 / 手動上書き）
  contactId String?
  companyId String?
  dealId    String?
  matchedBy String? // 'email_match' | 'manual'

  rawHeaders Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@unique([userId, gmailMessageId])
  @@index([orgId, contactId])
  @@index([orgId, companyId])
  @@index([orgId, dealId])
  @@index([gmailThreadId])
  @@index([orgId, sentAt(sort: Desc)])
}

enum EmailDirection {
  SENT
  RECEIVED
}

// ============================
// MEETING — Calendar / Meet イベント
// ============================
model MeetingEvent {
  id              String   @id @default(cuid())
  orgId           String
  userId          String
  calendarId      String   @default("primary")
  calendarEventId String
  iCalUID         String?

  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  meetUrl     String?
  meetCode    String?
  conferenceId String?

  attendeeEmails String[] @default([])
  organizerEmail String?

  // 紐付け（参加者メアド → コンタクト一致）
  primaryContactId String?
  contactIds       String[] @default([])
  companyId        String?
  dealId           String?

  status          MeetingStatus @default(SCHEDULED)
  // 取引上の n 回目商談（COMPLETED 時に算出）
  occurrenceIndex Int?
  meetingType     MeetingType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryContact Contact?     @relation(fields: [primaryContactId], references: [id], onDelete: SetNull)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal           Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  transcript     Transcript?

  @@unique([userId, calendarEventId])
  @@index([orgId, startsAt(sort: Desc)])
  @@index([orgId, dealId])
  @@index([orgId, primaryContactId])
  @@index([orgId, status])
}

enum MeetingStatus {
  SCHEDULED   // カレンダー登録済み（未開催）
  HELD        // 開催済み（議事録未取得）
  COMPLETED   // 議事録取得済み
  CANCELED
}

enum MeetingType {
  FIRST       // 初回商談
  FOLLOW_UP   // 2回目以降
  PROPOSAL    // 提案
  NEGOTIATION // 交渉
  CLOSING     // クロージング
  OTHER
}
